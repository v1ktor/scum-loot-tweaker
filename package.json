{
  "name": "scum-loot-tweaker",
  "private": true,
  "version": "1.0.0",
  "description": "Web app to tweak loot spawn in SCUM game",
  "type": "module",
  "scripts": {
    "ui:dev": "vite",
    "ui:build": "shx rm -rf dist && tsc && vite build",
    "ui:deploy": "gh-pages -d dist",
    "ui:preview": "vite preview",
    "server:dev": "npx tsx watch src/server/server.ts",
    "lint": "npx biome check --write ./src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/v1ktor/scum-loot-tweaker.git"
  },
  "author": "Viktor Kalinin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/v1ktor/scum-loot-tweaker/issues"
  },
  "homepage": "https://v1ktor.github.io/scum-loot-tweaker",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/env": "^5.0.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@sinclair/typebox": "^0.34.41",
    "bignumber.js": "^9.1.2",
    "fastify": "^5.6.0",
    "gh-pages": "^6.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-ga4": "^2.1.0",
    "react-router-dom": "^7.8.2",
    "react-select": "^5.10.2",
    "react-tabs": "^6.1.0",
    "react-tooltip": "^5.29.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "nodemon": "^3.1.10",
    "pino-pretty": "^11.2.2",
    "shx": "^0.3.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-static-copy": "^3.1.2"
  }
}
